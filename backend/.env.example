# Backend Configuration

# Port for local development (default: 3000)
PORT=3000

# NGROK Configuration (for remote access from VR and WiFi sensors)
# To enable ngrok:
# 1. Create free account at https://dashboard.ngrok.com
# 2. Copy your authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
# 3. Paste it below and set USE_NGROK=true

# Set to 'true' to enable ngrok tunnel
USE_NGROK=false

# Your ngrok authtoken (get from https://dashboard.ngrok.com/get-started/your-authtoken)
# Example: NGROK_AUTHTOKEN=2qH7X2x7hZ9pK0mT5lQ8w_6nB4cXyF9s0aR3pT5u
NGROK_AUTHTOKEN=
